{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": []
  },
  "include": [
    "src/**/*",
    "vite.renderer.config.ts",
    "package.json"
  ],
  "exclude": [
    "src/main.ts",
    "src/main/**/*",
    "src/preload.ts"
  ]
}
